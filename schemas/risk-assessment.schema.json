{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/risk-assessment.schema.json",
  "title": "KAVEEP Risk Assessment",
  "type": "object",
  "required": [
    "action_id",
    "action_name",
    "risk_level",
    "confidence_score",
    "evidence_count",
    "approval_required",
    "simulation_required",
    "rollback_available",
    "execution_allowed"
  ],
  "properties": {
    "action_id": {
      "type": "string"
    },
    "action_name": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": ["R0", "R1", "R2", "R3", "R4", "R5"]
    },
    "risk_reason": {
      "type": "string"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 0
    },
    "approval_required": {
      "type": "boolean"
    },
    "simulation_required": {
      "type": "boolean"
    },
    "rollback_available": {
      "type": "boolean"
    },
    "execution_allowed": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
